# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Multi-Agent Research Assistant"
ENVIRONMENT=development        # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-minimum-32-chars-change-this-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_db
POSTGRES_PASSWORD=postgres

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic (REQUIRED) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model configuration (optional — defaults shown)
ORCHESTRATOR_MODEL=claude-opus-4-5
RESEARCHER_MODEL=claude-sonnet-4-5
CRITIC_MODEL=claude-sonnet-4-5
SYNTHESIZER_MODEL=claude-sonnet-4-5

# ── Agent pipeline tuning ────────────────────────────────────────────────────
MAX_RESEARCHER_CONCURRENCY=3
MAX_REFINEMENT_ITERATIONS=2
RESEARCH_TIMEOUT_SECONDS=300
CONFIDENCE_THRESHOLD=0.6
MAX_SUBTOPICS=6

# ── Search APIs (at least one recommended) ───────────────────────────────────
# Brave Search: https://brave.com/search/api/
BRAVE_API_KEY=
# SerpAPI fallback: https://serpapi.com/
SERPAPI_KEY=
# Semantic Scholar: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ── Observability (optional but recommended) ─────────────────────────────────
# Langfuse: https://langfuse.com
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Sentry error tracking: https://sentry.io
SENTRY_DSN=

PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=admin

# ── Scaling ───────────────────────────────────────────────────────────────────
BACKEND_WORKERS=4
NODE_ENV=production
